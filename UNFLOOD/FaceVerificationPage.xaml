<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UNFLOOD.FaceVerificationPage"
             BackgroundColor="#F8FAFC">

    <Grid>
        <ContentPage.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0284C7" Offset="0.0" />
                <GradientStop Color="#0F172A" Offset="1.0" />
            </LinearGradientBrush>
        </ContentPage.Background>

        <Border StrokeShape="RoundRectangle 16" 
                Stroke="Transparent" 
                BackgroundColor="White" 
                Padding="35,30" 
                WidthRequest="440" 
                HorizontalOptions="Center" 
                VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.1"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="18" HorizontalOptions="Center">

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label x:Name="LabelRole" Text="Live Face Scanner" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#0284C7"/>
                    <Label x:Name="LabelStatus" Text="Arahkan wajah ke kamera untuk verifikasi." FontSize="12" HorizontalOptions="Center" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <Frame CornerRadius="12" Padding="0" IsClippedToBounds="True" BackgroundColor="#F1F5F9" HeightRequest="280" WidthRequest="360" BorderColor="#CBD5E1">
                    <Grid>
                        <Image x:Name="CameraPreview" Aspect="AspectFill" />
                        <ActivityIndicator x:Name="ScanIndicator" IsRunning="False" IsVisible="False" Color="#0284C7" HeightRequest="50" WidthRequest="50" VerticalOptions="Center" HorizontalOptions="Center"/>
                    </Grid>
                </Frame>

                <Label x:Name="LabelSimilarity" Text="Status: Standby" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#0F172A" HorizontalTextAlignment="Center"/>

                <Button Text="🔄 MULAI ULANG SCANNER" FontAttributes="Bold" BackgroundColor="#64748B" TextColor="White" CornerRadius="8" HeightRequest="44" Clicked="OnStartScanClicked" />
                <Button Text="Kembali ke Login" BackgroundColor="Transparent" TextColor="#EF4444" FontAttributes="Bold" Clicked="OnCancelClicked" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>